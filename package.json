{
  "name": "liminal-prototype",
  "version": "0.1.0",
  "description": "Public interactive prototype for Liminal Agents — workflow demo with bounded refusal, deliberation, correction, and vault loops.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node server.mjs",
    "start": "node server.mjs",
    "build:kernel": "bun build ../liminal-test/src/browser.ts --target=browser --format=esm --outfile=lib/osint-kernel.bundle.js",
    "tokens:sync": "node scripts/tokens/sync-upstream.mjs",
    "tokens:check": "node scripts/tokens/sync-upstream.mjs --check",
    "test": "playwright test",
    "test:headed": "playwright test --headed"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
